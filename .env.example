# WebRTC Signaling Server Configuration
# Copy this to .env and update with your values

# ============= SERVER CONFIGURATION =============
NODE_ENV=production
PORT=3000

# ============= CORS CONFIGURATION =============
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080,https://yourdomain.com

# ============= SOCKET.IO CONFIGURATION =============
# Maximum number of connections per client
SOCKET_IO_MAX_HTTP_BUFFER_SIZE=1e6

# Ping interval (milliseconds)
SOCKET_IO_PING_INTERVAL=25000

# Ping timeout (milliseconds)
SOCKET_IO_PING_TIMEOUT=60000

# ============= LOGGING =============
# log level: debug, info, warn, error
LOG_LEVEL=info

# ============= MONITORING & ANALYTICS =============
# Enable connection logging
ENABLE_CONNECTION_LOGGING=true

# ============= SIGNALING SERVER URLS =============
# For production deployment, set these to your server URLs

# Socket.IO Server (for testing locally)
SOCKETIO_SERVER_URL=http://localhost:3000

# PeerJS Server (if self-hosting)
PEERJS_SERVER_URL=http://localhost:9000
PEERJS_SERVER_PATH=/peerjs

# OpenVidu Server (if deployed)
OPENVIDU_URL=https://localhost:4443
OPENVIDU_SECRET=your-openvidu-secret

# ============= VERCEL / RAILWAY DEPLOYMENT =============
# Set these when deploying to Vercel or Railway

# For Railway deployment
RAILWAY_ENVIRONMENT_NAME=production

# ============= TURN SERVERS (Optional) =============
# Add TURN servers for better NAT traversal
TURN_SERVER_1=turn:your-turn-server.com:3478
TURN_SERVER_1_USERNAME=username
TURN_SERVER_1_PASSWORD=password

TURN_SERVER_2=turn:backup-turn-server.com:3478
TURN_SERVER_2_USERNAME=username
TURN_SERVER_2_PASSWORD=password

# ============= DATABASE (Optional, for production) =============
# If you want to log connections/sessions
DATABASE_URL=postgresql://user:password@localhost:5432/webrtc

# ============= SECURITY =============
# Add any API keys or secrets here
API_KEY=your-api-key-here
SESSION_SECRET=your-session-secret-here

# ============= RATE LIMITING =============
# Rate limit requests per minute per IP
RATE_LIMIT_REQUESTS_PER_MINUTE=100

# ============= AUTHENTICATION (Optional) =============
# Enable authentication for signaling
ENABLE_AUTH=false
AUTH_TOKEN_SECRET=your-secret-key

# ============= METRICS & MONITORING =============
# Enable Prometheus metrics
ENABLE_METRICS=false
METRICS_PORT=9090

# ============= EMAIL ALERTS (Optional) =============
# Send alerts if server issues detected
ENABLE_EMAIL_ALERTS=false
ALERT_EMAIL=admin@example.com
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASSWORD=password
